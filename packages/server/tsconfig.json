{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"composite": true,
		"jsx": "react-jsx",
		"jsxImportSource": "nano-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true
	},
	"include": ["routes", "plugins", "lib", "*.ts"],
	"references": [
		{ "path": "../shared" },
		{ "path": "../lexicons" }
	]
}
