{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"strict": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"types": ["bun"],
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src"]
}
