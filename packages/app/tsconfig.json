{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"resolveJsonModule": true,
		"allowJs": true,
		"composite": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"moduleResolution": "bundler",
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "build", "../../package/dist", "src/packs/*/pack.ts"],
	"references": [
		{ "path": "../shared" }
	]
}
