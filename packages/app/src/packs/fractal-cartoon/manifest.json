{
  "schemaVersion": 1,
  "name": "Fractal Cartoon",
  "version": "0.1.0",
  "author": "Kali (Shadertoy)",
  "description": "Raymarched fractal landscape with cartoon edge detection, animated sun, and rainbow trail. Based on Kali's 'Fractal Cartoon' from Shadertoy.",
  "shader": "shader.glsl",
  "tags": ["glsl"],
  "parameters": [
    { "type": "float", "name": "speed", "label": "speed", "min": 0.1, "max": 3.0, "default": 1.0 },
    { "type": "float", "name": "brightness", "label": "brightness", "min": 0.5, "max": 2.5, "default": 1.2 },
    { "type": "float", "name": "wave_intensity", "label": "wave intensity", "min": 0.0, "max": 1.0, "default": 0.5 },
    { "type": "float", "name": "edge_strength", "label": "edge strength", "min": 0.0, "max": 1.5, "default": 0.8 }
  ],
  "presets": [
    { "name": "Default", "values": { "speed": 1.0, "brightness": 1.2, "wave_intensity": 0.5, "edge_strength": 0.8 } },
    { "name": "Dreamy", "values": { "speed": 0.4, "brightness": 1.5, "wave_intensity": 0.8, "edge_strength": 0.3 } },
    { "name": "Harsh", "values": { "speed": 2.0, "brightness": 1.0, "wave_intensity": 0.2, "edge_strength": 1.4 } }
  ]
}
