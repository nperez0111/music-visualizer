		{
			"name": "Subway",
			"values": { "speed": 0.8, "tint": [0.6, 0.8, 1.0], "divisions": 24.0 }
		},
		{
			"name": "Vaporwave",
			"values": { "speed": 1.4, "tint": [1.0, 0.5, 0.9], "divisions": 16.0 }
		}
	]
