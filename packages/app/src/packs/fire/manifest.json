		{
			"name": "Cool Embers",
			"values": { "height": 0.40, "hotColor": [0.4, 0.6, 1.0], "embers": true }
		},
		{
			"name": "Calm Hearth",
			"values": { "height": 0.30, "hotColor": [1.0, 0.85, 0.4], "embers": false }
