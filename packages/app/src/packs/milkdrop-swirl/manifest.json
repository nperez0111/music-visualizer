{
	"schemaVersion": 1,
	"id": "milkdrop-swirl",
	"name": "Milkdrop Swirl",
	"version": "1.1.0",
	"author": "nickthesick.com",
	"description": "Geiss-flavored fluid swirl — domain-warped FBM with palette cycling. Bass kicks up vorticity, treble adds glitter.",
	"tags": ["fluid", "retro", "trippy"],
	"shader": "shader.wgsl",
	"parameters": [
		{
			"type": "float",
			"name": "paletteShift",
			"label": "palette offset",
			"min": 0.0,
			"max": 1.0,
			"default": 0.0
		},
		{
			"type": "float",
			"name": "warpAmount",
			"label": "warp amount",
			"min": 0.0,
			"max": 2.0,
			"default": 1.0
		},
		{
			"type": "bool",
			"name": "glitter",
			"label": "treble glitter",
			"default": true
		}
	]
}
