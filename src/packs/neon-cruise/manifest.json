{
	"schemaVersion": 1,
	"id": "neon-cruise",
	"name": "Neon Cruise",
	"version": "0.1.0",
	"author": "music-visualizer",
	"description": "Wireframe car cruising down a neon-outlined cityscape; buildings on either side fly past with heights pumping to the beat.",
	"tags": ["3d", "retro", "dark"],
	"shader": "shader.wgsl",
	"parameters": [
		{
			"type": "float",
			"name": "speed",
			"label": "speed",
			"min": 0.0,
			"max": 4.0,
			"default": 1.0
		},
		{
			"type": "float",
			"name": "pulse",
			"label": "pulse",
			"min": 0.0,
			"max": 2.0,
			"default": 1.0
		},
		{
			"type": "color",
			"name": "tint",
			"label": "tint",
			"default": [0.4, 0.95, 1.0]
		},
		{
			"type": "float",
			"name": "cycle",
			"label": "color cycle",
			"min": 0.0,
			"max": 1.5,
			"default": 0.0
		}
	],
	"presets": [
		{ "name": "Cyan Glide",  "values": { "speed": 1.0, "pulse": 1.0, "tint": [0.4, 0.95, 1.0], "cycle": 0.0 } },
		{ "name": "Magenta Run", "values": { "speed": 1.4, "pulse": 1.3, "tint": [1.0, 0.45, 0.95], "cycle": 0.0 } },
		{ "name": "Gold Lane",   "values": { "speed": 0.7, "pulse": 0.9, "tint": [1.0, 0.85, 0.35], "cycle": 0.0 } },
		{ "name": "Rainbow Run", "values": { "speed": 1.2, "pulse": 1.1, "tint": [1.0, 0.7, 0.7], "cycle": 0.8 } }
	]
}
